{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^T-(.*)": "@/components/TarotCard/$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "卡牌抽牌",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/draw/draw",
      "style": {
        "navigationBarTitleText": "抽牌",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/result/result",
      "style": {
        "navigationBarTitleText": "抽牌结果",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/cards/cards",
      "style": {
        "navigationBarTitleText": "牌库",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "抽牌记录",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/profile-detail/profile-detail",
      "style": {
        "navigationBarTitleText": "个人资料",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/checkin/checkin",
      "style": {
        "navigationBarTitleText": "每日签到",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/tasks/tasks",
      "style": {
        "navigationBarTitleText": "任务中心",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/invite/invite",
      "style": {
        "navigationBarTitleText": "邀请好友",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/invite-input/invite-input",
      "style": {
        "navigationBarTitleText": "输入邀请码",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/feedback/feedback",
      "style": {
        "navigationBarTitleText": "意见反馈",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/feedback-list/feedback-list",
      "style": {
        "navigationBarTitleText": "反馈记录",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/feedback-detail/feedback-detail",
      "style": {
        "navigationBarTitleText": "反馈详情",
        "navigationBarBackgroundColor": "#1a1a2e",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarBackgroundColor": "#1a1a2e",
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "卡牌抽牌",
    "backgroundColor": "#0f0f23"
  },
  "tabBar": {
    "custom": true,
    "color": "#666",
    "selectedColor": "#c9a96e",
    "backgroundColor": "#1a1a2e",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/draw/draw",
        "text": "抽牌"
      },
      {
        "pagePath": "pages/cards/cards",
        "text": "牌库"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的"
      }
    ]
  }
}
